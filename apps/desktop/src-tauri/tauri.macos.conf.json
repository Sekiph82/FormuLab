{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Open Science",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "zoomHotkeysEnabled": false,
        "trafficLightPosition": { "x": 13, "y": 22 },
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ]
  }
}
